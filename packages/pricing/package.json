{
  "name": "@serenity-star/pricing",
  "version": "0.1.0",
  "description": "A web component pricing section built with Svelte 5",
  "main": "dist/pricing.iife.js",
  "module": "dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build:css": "npx @tailwindcss/cli -i ./src/app.css -o ./src/styles.css",
    "build": "npm run build:css && npm run postprocess:css && vite build --config vite.config.esm.ts && vite build --config vite.config.iife.ts",
    "postprocess:css": "postcss ./src/styles.css -o ./src/styles.css",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json"
  },
  "type": "module",
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/cli": "^4.1.10",
    "@tsconfig/svelte": "^5.0.4",
    "postcss-cli": "^11.0.1",
    "svelte": "^5.28.1",
    "svelte-check": "^4.1.6",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@lucide/svelte": "^0.515.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@tailwindcss/postcss": "^4.1.10",
    "@tailwindcss/vite": "^4.1.10",
    "autoprefixer": "^10.4.21",
    "clsx": "^2.1.1",
    "postcss": "^8.5.5",
    "postcss-prefix-selector": "^2.1.1",
    "tailwindcss": "^4.1.10",
    "tailwindcss-animate": "^1.0.7",
    "vite-plugin-dts": "^4.5.4"
  },
  "author": "Mauro Garcia",
  "license": "MIT",
  "keywords": [
    "web-component",
    "pricing",
    "svelte",
    "component"
  ]
}
